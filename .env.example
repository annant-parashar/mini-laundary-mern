# MongoDB Connection String (use MongoDB Atlas for production)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/laundry?retryWrites=true&w=majority

# JWT Secret Key
JWT_SECRET=your_jwt_secret_key_here

# Server Port (local development)
PORT=5000

# Frontend URL (for CORS - used in production)
CLIENT_URL=http://localhost:5173

# Backend API URL (used by frontend)
VITE_API_URL=http://localhost:5000/api
